problem: https://leetcode.com/problems/minimum-distance-to-the-target-element/description/?envType=daily-question&envId=2026-04-13

solution:
class Solution {
public:
    int getMinDistance(vector<int>& nums, int target, int start) {
        int result = nums.size();
        for(int i=0;i<nums.size();i++){
            if(nums[i]==target)
                result = min(result,abs(i-start));
        }
        return result;

    }
};
