problem: https://leetcode.com/problems/find-all-possible-stable-binary-arrays-i/description/?envType=daily-question&envId=2026-03-09

solution:
class Solution {
public:
    int numberOfStableArrays(int zero, int one, int limit) {
        const int mod = 1e9+7;

        vector<vector<int>> dp1(zero + 1, vector<int>(one + 1, 0));
        vector<vector<int>> dp2(zero + 1, vector<int>(one + 1, 0));

        for (int i = 1; i <= min(zero, limit); ++i) dp1[i][0] = 1;
        for (int j = 1; j <= min(one, limit); ++j) dp2[0][j] = 1;

        for (int i = 1; i <= zero; ++i) {
            for (int j = 1; j <= one; ++j) {
                for (int k = 1; k <= min(limit, i); ++k)
                    dp1[i][j] = (dp1[i][j] + dp2[i - k][j]) % mod;
                for (int k = 1; k <= min(limit, j); ++k)
                    dp2[i][j] = (dp2[i][j] + dp1[i][j - k]) % mod;
            }
        }

        return (dp1[zero][one] + dp2[zero][one]) % mod;
    }
};
