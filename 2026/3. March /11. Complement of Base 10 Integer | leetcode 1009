problem: https://leetcode.com/problems/complement-of-base-10-integer/description/?envType=daily-question&envId=2026-03-11

solution:
class Solution {
public:
    int bitwiseComplement(int n) {
        int mask = 1;
        while (mask < n)
            mask = (mask << 1) + 1;

        return mask ^ n;
    }
};
